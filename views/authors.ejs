<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of Authors</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>
</head>
<body>

    <h1 class="p-5 bg-dark text-white" style="text-align: center;"> Authors </h1>
    <%- include('partials/header') %>


    <% for (author of rows) { %>

    <a href="/editAuthor?authorId=<%= author.authorId %>"><button type="button" class="btn btn-success"> Update </button></a>
    <a href="/deleteAuthor?authorId=<%= author.authorId %>"><button type="button" class="btn btn-danger"> Delete </button></a>  
    <%= author.authorId %> <%= author.firstName %> <%=  author.lastName %>
    <br>

    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>