<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Updating Existing Author</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>
</head>
<body>
    
    <h1 class="p-5 bg-dark text-white" style="text-align: center;"> Author Update</h1>
    <%- include('partials/header') %>


    <form method="POST" action="/editAuthor">

        <input type="hidden" name="authorId" value="<%= authorInfo[0].authorId %>">
        
        First Name: 
        <input value="<%= authorInfo[0].firstName %>" name="firstName" type="text">
        <br>
        
        Last Name: 
        <input value="<%= authorInfo[0].lastName %>" name="lastName" type="text">
        <br>

        Country:
        <input value="<%= authorInfo[0].country %>" name="country" type="text">
        <br>

        Profession:
        <input value="<%= authorInfo[0].profession %>" name="profession" type="text">
        <br>
        
    
        Date of birth:
        <input type="date" name="dob" value="<%= authorInfo[0].dob ? authorInfo[0].dob : ''%>">
        <br>

        Date of death:
        <input type="date" name="dod" value="<%= authorInfo[0].dob ? authorInfo[0].dod : ''%>">
        <br>

        Sex: <%= authorInfo[0].sex%>

        <input 
        
        <% if (authorInfo[0].sex == "F") { %>
        checked 
        <% } %>
        
        type="radio" name="sex" value="F"> Female
        <input type="radio" name="sex" value="M"> Male <br>
        
        Bio:
        <textarea name="biography"><%= authorInfo[0].biography %></textarea>
        <button> Edit Author </button>

        
        

    </form>

    <script src="/js/author.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>