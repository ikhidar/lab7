<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Updating Existing Author</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>
</head>
<body>
    
    <h1 class="p-5 bg-dark text-white" style="text-align: center;" > Quote Update</h1>
    <%- include('partials/header') %>


    <hr>
    <%=quoteInfo[0].quoteId%><br>
    <%=quoteInfo[0].quote%><br>
    AuthorId: <%=quoteInfo[0].authorId%><br>
    <%=quoteInfo[0].category%><br>
    <%=quoteInfo[0].likes%><br>
    <hr>

    <form method="POST" action="/editQuote">
        <textarea><%=quoteInfo[0].quote%></textarea><br>
        <button>Update Quote</button>

    </form>
 <form method="POST" action="/editQuote">  
    <input type="hidden" name="quoteId" value=""> 
    <label>
        Author:
        <select name="authorId">
            <% for (i of authors){%>
            <option selected value="<%i.authorId%>">
                <%=i.firstName%> <%=i.lastName%></option>
            <% } %>
        </select>
    </label>
</form>
    <script src="/js/author.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>