<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adding New Author</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>
</head>
<body>
    
    <h1 class="p-5 bg-dark text-white" style="text-align: center;"> New Author </h1>
    <%- include('partials/header') %>


    <form method="POST" action="/addAuthor">

        First Name: 
        <input  name="firstName" type="text">
        <br>
        Last Name: 
        <input name="lastName" type="text">
        <br>
        Country:
        <input name="country" type="text">
        <br>
        Profession:
        <input name="profession" type="text">
        <br>
        DOB:
        <input type="date" name="dob">
        <br>
        DOD:
        <input type="date" name="dod">
        <br>
        Sex:
        <input type="radio" name="sex" value="M"> Male
        <input type="radio" name="sex" value="F"> Female
        <br>
        Biography:
        <textarea name="biography"></textarea>
        <br>
        <button type="submit" class="btn btn-success"> Add Author</button>

    </form>

    <script src="/js/author.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>