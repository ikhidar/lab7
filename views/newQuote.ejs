<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adding new Quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
</head>
</head>
<body>
    <h1 class="p-5 bg-dark text-white"  style="text-align: center;"> New Quote </h1>

    <%- include('partials/header') %>


    <form method="POST" action="/addQuote">
        Quote:
        <textarea name="quote"></textarea><br>
        <label>
        Author:
        <select name="authorId">
            <% for (i of rows){%>
            <option value="<%=i.authorId%>">
                <%=i.firstName%> <%=i.lastName%></option>
            <% } %>
        </select>
        <br>
        Category:
        <input type="text" name="category"><br>
        <br>
        <button type="submit" class="btn btn-success"> Add Quote</button>
    </form>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>