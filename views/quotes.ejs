<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of Authors</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
</head>
<body>
    <h1 class="p-5 bg-dark text-white" style="text-align: center;"> Quotes </h1>
    <%- include('partials/header') %>


    <% for (i of rows) { %>

    <a href="/editQuote?quoteId=<%= i.quoteId %>"><button type="button" class="btn btn-success"> Update </button></a>
    <a href="/deleteQuote?quoteId=<%= i.quoteId %>"><button type="button" class="btn btn-danger"> Delete </button></a>
    <%= i.quoteId %> <%= i.quote %>
    <br>

    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>